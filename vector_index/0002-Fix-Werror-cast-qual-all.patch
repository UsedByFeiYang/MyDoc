From fcec17a206ea16469178a02133ebfffb44d14318 Mon Sep 17 00:00:00 2001
From: Developer <developer@example.com>
Date: Fri, 24 Apr 2026 17:50:13 +0800
Subject: [PATCH 3/3] Fix dd::Table::ST_NONE/PT_NONE compatibility across MySQL
 versions

Replace dd::Table::PT_NONE and dd::Table::ST_NONE with portable
dd::Table::enum_partition_type(0) and dd::Table::enum_subpartition_type(0).
Some MySQL 8.0.x community builds do not expose these unscoped enum
constants directly through the class scope.
---
 sql/vidx/vidx_hnsw.cc | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/sql/vidx/vidx_hnsw.cc b/sql/vidx/vidx_hnsw.cc
index 614962b0ab0..8677dbdf250 100644
--- a/sql/vidx/vidx_hnsw.cc
+++ b/sql/vidx/vidx_hnsw.cc
@@ -1197,8 +1197,8 @@ std::unique_ptr<dd::Table> create_dd_table(THD *thd, const char *table_name,
   hlindex_dd->set_comment(
       dd::String_type(key->comment.str, key->comment.length));
   hlindex_dd->set_row_format(dd_table->row_format());
-  hlindex_dd->set_partition_type(dd::Table::PT_NONE);
-  hlindex_dd->set_subpartition_type(dd::Table::ST_NONE);
+  hlindex_dd->set_partition_type(dd::Table::enum_partition_type(0));
+  hlindex_dd->set_subpartition_type(dd::Table::enum_subpartition_type(0));
   /* some properties have been set in Schema_impl::create_table(). */
 
   /* Options */
-- 
2.43.0

