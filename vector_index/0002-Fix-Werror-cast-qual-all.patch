From 9dbb267e94e19f5c9fa88fdf731790d69f598073 Mon Sep 17 00:00:00 2001
From: Developer <developer@example.com>
Date: Fri, 24 Apr 2026 17:25:03 +0800
Subject: [PATCH 2/3] Fix -Werror=cast-qual errors in vidx source files

Remove C-style casts that stripped const qualifiers across all vidx files:
- vidx_func.h: use static_cast<const Item_func*> for const Item* downcast
- sql_queue.h: remove const from push/safe_push/replace_top params;
  use reinterpret_cast/const_cast; fix queue_is_full in const method
- vidx_hnsw.cc: FVector::data() add non-const overload, fix const overload;
  FVector::create() const void* src -> const float*;
  AVX2/AVX512 dot_product v1/v2 -> const __m256i*/const __m512i*;
  String::ptr() result -> const uchar*; gref() use const_cast
- bloom_filters.h: masks (const uint8_t[]) read via reinterpret_cast<const>
- vidx_index.cc: const dd::Table* -> const_cast for options().remove()
---
 include/vidx/bloom_filters.h |  2 +-
 include/vidx/sql_queue.h     | 16 ++++++++--------
 include/vidx/vidx_func.h     |  2 +-
 sql/vidx/vidx_hnsw.cc        | 19 +++++++++++--------
 sql/vidx/vidx_index.cc       |  2 +-
 5 files changed, 22 insertions(+), 19 deletions(-)

diff --git a/include/vidx/bloom_filters.h b/include/vidx/bloom_filters.h
index 53381dab57f..a36a724059b 100644
--- a/include/vidx/bloom_filters.h
+++ b/include/vidx/bloom_filters.h
@@ -359,7 +359,7 @@ struct PatternedSimdBloomFilter {
     uint64_t maskIdx = hash & maskIdxMask;
     uint64_t maskByteIdx = maskIdx >> 3;
     uint64_t maskBitIdx = maskIdx & 7;
-    uint64_t rawMask = *(uint64_t *)(masks + maskByteIdx);
+    uint64_t rawMask = *reinterpret_cast<const uint64_t *>(masks + maskByteIdx);
     uint64_t unrotated = (rawMask >> maskBitIdx) & maskMask;
     uint64_t rotation = (hash >> mask_idx_bits) & ((1 << rotate_bits) - 1);
     return rotation ? (unrotated << rotation) | (unrotated >> (64 - rotation))
diff --git a/include/vidx/sql_queue.h b/include/vidx/sql_queue.h
index c980235da5a..0cabc6b5616 100644
--- a/include/vidx/sql_queue.h
+++ b/include/vidx/sql_queue.h
@@ -56,27 +56,27 @@ class Queue {
   int init(uint max_elements, bool max_at_top, queue_compare compare,
            Param *param = 0) {
     return init_queue(&m_queue, key_memory_vidx_mem, max_elements, 0,
-                      max_at_top, compare, (void *)param);
+                      max_at_top, compare, static_cast<void *>(param));
   }
 
   size_t elements() const { return m_queue.elements; }
   bool is_inited() const { return is_queue_inited(&m_queue); }
-  bool is_full() const { return queue_is_full((QUEUE *)(&m_queue)); }
+  bool is_full() const { return queue_is_full(const_cast<QUEUE *>(&m_queue)); }
   bool is_empty() const { return elements() == 0; }
   Element *top() const { return (Element *)queue_top(&m_queue); }
 
-  void push(const Element *element) {
-    queue_insert(&m_queue, (uchar *)element);
+  void push(Element *element) {
+    queue_insert(&m_queue, reinterpret_cast<uchar *>(element));
   }
-  void safe_push(const Element *element) {
+  void safe_push(Element *element) {
     if (is_full()) m_queue.elements--;  // remove one of the furthest elements
-    queue_insert(&m_queue, (uchar *)element);
+    queue_insert(&m_queue, reinterpret_cast<uchar *>(element));
   }
   Element *pop() { return (Element *)queue_remove_top(&m_queue); }
   void clear() { queue_remove_all(&m_queue); }
   void propagate_top() { queue_replaced(&m_queue); }
-  void replace_top(const Element *element) {
-    queue_top(&m_queue) = (uchar *)element;
+  void replace_top(Element *element) {
+    queue_top(&m_queue) = reinterpret_cast<uchar *>(element);
     propagate_top();
   }
 
diff --git a/include/vidx/vidx_func.h b/include/vidx/vidx_func.h
index e5ac9625ef5..7244effd69e 100644
--- a/include/vidx/vidx_func.h
+++ b/include/vidx/vidx_func.h
@@ -125,7 +125,7 @@ class Item_func_vector_dim : public Item_int_func {
 
 static inline bool check_item_func_vec_distance(const Item *item) {
   return item->type() == Item::FUNC_ITEM &&
-         ((Item_func *)item)->functype() == Item_func::VECTOR_DISTANCE_FUNC;
+         static_cast<const Item_func *>(item)->functype() == Item_func::VECTOR_DISTANCE_FUNC;
 }
 }  // namespace vidx
 
diff --git a/sql/vidx/vidx_hnsw.cc b/sql/vidx/vidx_hnsw.cc
index 00a751370de..614962b0ab0 100644
--- a/sql/vidx/vidx_hnsw.cc
+++ b/sql/vidx/vidx_hnsw.cc
@@ -81,7 +81,8 @@ struct FVector {
